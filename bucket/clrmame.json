{
    "version": "0.6.2",
    "description": "Little tool to scan and rebuild MAME (https://www.mamedev.org/) machine sets.",
    "homepage": "https://mamedev.emulab.it/clrmamepro/",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://mamedev.emulab.it/clrmamepro/binaries/clrmame_v062.zip",
            "hash": "ebba8f6dd44cee618d75cb41c2490407bf0543e220dc04e0396d2da6154a953e"
        }
    },
    "bin": "clrmame.exe",
    "shortcuts": [
        [
            "clrmameUI.exe",
            "clrmameUI"
        ]
    ],
    "pre_install": "@(\"settings.xml\") | ForEach-Object {if (!(Test-Path \"$persist_dir\\$_\")) { New-Item \"$dir\\$_\" -ItemType File > $null }}",
    "persist": [
        "settings.xml",
        "fixdats",
        "exports",
        "scans"
    ],
    "checkver": {
        "regex": ">clrmame (.*)</a></td>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://mamedev.emulab.it/clrmamepro/binaries/clrmame_v$cleanVersion.zip"
            }
        }
    }
}
